programa  
{  
    funcao inicio()  
    {  
        real aresta, area  
  
        faca   
        {  
            escreva ("Para calcular a área do quadrado informe o valor de um lado: ")  
            leia (aresta)  
        } enquanto (aresta <= 0)  
  
        area=aresta*4 
        escreva("A área é: ", area)  
    }  
}  
